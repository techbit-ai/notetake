// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: notes
// Document ID: auto-generated
// Fields:
//   - content: string (required) - The original snippet
//   - structuredData: map (optional) - AI metadata { summary, tags, keyPoints }
//   - userId: string (required) - Owner UID
//   - createdAt: timestamp (required)
//   - source: string (optional)
//   - embedding: list (optional) - Vector embedding
//
// Collection: users
// Document ID: userId
// Fields:
//   - email: string (required)
//   - displayName: string (optional)
//   - role: string (required) - 'user' or 'admin'
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sidkstech@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidNote(data) {
      return data.keys().hasAll(['content', 'userId', 'createdAt']) &&
             data.content is string && data.content.size() < 5000 &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('embedding' in data) || data.embedding is list);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notes/{noteId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isDocOwner() && isValidNote(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role;
    }
  }
}
